.venv/
__pycache__/
*.pyc
.pytest_cache/
cache/
.DS_Store

# Stray .obsidian at repo root (happens if Obsidian opens the project root by mistake — the real vault is in vault/)
/.obsidian/

# Ignore vault data, but keep the scaffolding (Dashboard, README, Obsidian config, CSS).
vault/*
!vault/Dashboard.md
!vault/README.md
!vault/.obsidian/
vault/.obsidian/*
!vault/.obsidian/graph.json
!vault/.obsidian/appearance.json
!vault/.obsidian/community-plugins.json
!vault/.obsidian/snippets/
!vault/.obsidian/snippets/**

# Phase 2 — gold-set ground-truth is reference data, not transient.
# Auto-generated CSVs/JSON in vault/_export/ stay ignored.
!vault/_export/
vault/_export/*
!vault/_export/ground_truth/
!vault/_export/ground_truth/**
logs/
